# OpenMTSN Environment Configuration
# Copy to .env and customise for your deployment

# ── Redis ─────────────────────────────────────
MTSN_REDIS_URL=redis://localhost:6379/0
MTSN_REDIS_NODE_TTL_SECONDS=30

# ── CORS ──────────────────────────────────────
MTSN_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Logging ───────────────────────────────────
MTSN_LOG_LEVEL=INFO

# ── Routing Thresholds ────────────────────────
MTSN_PACKET_LOSS_FAILOVER_THRESHOLD=15.0
MTSN_SIGNAL_STRENGTH_FAILOVER_THRESHOLD=30
MTSN_LATENCY_WARNING_THRESHOLD_MS=200.0
